<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7C4A5">

    <!-- Header Layout with Dark Background -->


    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:gravity="center">

            <!-- Vehicle No. Input -->
            <EditText
                android:id="@+id/vehicleNoEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Vehicle No."
                android:padding="16dp"
                android:background="@drawable/filled_edit_text"
                android:inputType="text"
                android:textColor="#333333"
                android:textColorHint="#888888"/>

            <!-- Vehicle No. Validation Text -->
            <TextView
                android:id="@+id/vehicleNoValidationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/vehicleNoEditText"
                android:layout_marginTop="5dp"
                android:text="Please enter a valid vehicle number"
                android:textColor="#FF0000"
                android:textSize="14sp"
                android:visibility="gone"/>

            <!-- Model Name Input -->
            <EditText
                android:id="@+id/modelNameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/vehicleNoValidationText"
                android:layout_marginTop="20dp"
                android:hint="Model Name"
                android:padding="16dp"
                android:background="@drawable/filled_edit_text"
                android:inputType="text"
                android:textColor="#333333"
                android:textColorHint="#888888"/>

            <!-- Model Name Validation Text -->
            <TextView
                android:id="@+id/modelNameValidationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/modelNameEditText"
                android:layout_marginTop="5dp"
                android:text="Please enter a valid model name"
                android:textColor="#FF0000"
                android:textSize="14sp"
                android:visibility="gone"/>

            <!-- Details Input -->
            <EditText
                android:id="@+id/detailsEditText"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_below="@id/modelNameValidationText"
                android:layout_marginTop="20dp"
                android:hint="Details"
                android:padding="16dp"
                android:background="@drawable/filled_edit_text"
                android:inputType="textMultiLine"
                android:minLines="4"
                android:gravity="top"
                android:textColor="#333333"
                android:textColorHint="#888888"/>

            <!-- Details Validation Text -->
            <TextView
                android:id="@+id/detailsValidationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/detailsEditText"
                android:layout_marginTop="5dp"
                android:text="Please enter complaint details"
                android:textColor="#FF0000"
                android:textSize="14sp"
                android:visibility="gone"/>

            <!-- Problem Close Switch -->
            <LinearLayout
                android:id="@+id/problemCloseLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/detailsValidationText"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Problem Close"
                    android:textColor="#333333"
                    android:textSize="16sp"/>

                <Switch
                    android:id="@+id/problemCloseSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Remarks Input -->
            <EditText
                android:id="@+id/remarksEditText"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_below="@id/problemCloseLayout"
                android:layout_marginTop="20dp"
                android:hint="Remarks"
                android:padding="16dp"
                android:background="@drawable/filled_edit_text"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:textColor="#333333"
                android:textColorHint="#888888"/>

            <!-- Remarks Validation Text -->
            <TextView
                android:id="@+id/remarksValidationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/remarksEditText"
                android:layout_marginTop="5dp"
                android:text="Please enter remarks"
                android:textColor="#FF0000"
                android:textSize="14sp"
                android:visibility="gone"/>

            <!-- Submit Button -->
            <Button
                android:id="@+id/submitButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/remarksValidationText"
                android:layout_marginTop="30dp"
                android:background="@drawable/filled_button_black"
                android:text="Save"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="14dp"/>
        </RelativeLayout>
    </ScrollView>
</RelativeLayout>