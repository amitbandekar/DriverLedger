<?xml version="1.0" encoding="utf-8"?>


    <RelativeLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FEFAE0"
    android:layout_marginBottom="16dp"

        android:padding="16dp">

        <TextView
            android:id="@+id/tvVehicleNo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:text="Vehicle No: KA01GH3456"/>

        <TextView
            android:id="@+id/tvModelName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvVehicleNo"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/black"
            android:text="Model: Nissan Altima"/>

        <TextView
            android:id="@+id/tvTyreQty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvModelName"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/black"
            android:text="Tyre Quantity: 4"/>

        <TextView
            android:id="@+id/tvAlignmentKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvTyreQty"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/black"
            android:text="Alignment KM: 30,000"/>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvAlignmentKm"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/black"
            android:text="Date: 28-September-24"/>

        <ImageView
            android:id="@+id/ivDelete"
            android:layout_width="20dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="14dp"
            android:contentDescription="Delete"
            android:src="@drawable/ic_delete" />

    </RelativeLayout>